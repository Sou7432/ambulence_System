# Copy to .env and fill in values

# Flask
SECRET_KEY=change-this-in-production
PORT=5000

# Optional: Google Gemini for AI summaries (otherwise rule-based triage runs)
GEMINI_API_KEY=
# Optional model override (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Optional: Google Maps JavaScript API key for the ambulance map
GOOGLE_MAPS_API_KEY=
